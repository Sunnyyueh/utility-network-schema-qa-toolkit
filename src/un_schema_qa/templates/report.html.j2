<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ result.project_name }} — Utility Network Schema QA</title>
  <style>
    :root { color-scheme: light; --ink: #17212b; --muted: #53616f; --line: #d8e0e7; --panel: #f6f8fa; --accent: #075985; --error: #b42318; --warning: #a15c00; --info: #1d4ed8; }
    * { box-sizing: border-box; }
    body { margin: 0; color: var(--ink); background: #fff; font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; line-height: 1.5; }
    header, main, footer { width: min(1180px, calc(100% - 2rem)); margin-inline: auto; }
    header { padding: 2rem 0 1rem; border-bottom: 1px solid var(--line); }
    h1, h2 { line-height: 1.2; }
    h1 { margin: 0 0 .5rem; font-size: clamp(1.6rem, 4vw, 2.4rem); }
    h2 { margin-top: 2rem; }
    .meta { color: var(--muted); overflow-wrap: anywhere; }
    .summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: .75rem; margin: 1.5rem 0; }
    .card { padding: 1rem; border: 1px solid var(--line); border-radius: .5rem; background: var(--panel); }
    .card strong { display: block; font-size: 1.5rem; }
    .status { text-transform: uppercase; letter-spacing: .04em; color: var(--accent); }
    .table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: .5rem; }
    table { width: 100%; border-collapse: collapse; font-size: .925rem; }
    th, td { padding: .65rem .75rem; border-bottom: 1px solid var(--line); text-align: left; vertical-align: top; }
    th { background: var(--panel); }
    tr:last-child td { border-bottom: 0; }
    code { overflow-wrap: anywhere; }
    .severity-error { color: var(--error); font-weight: 700; }
    .severity-warning { color: var(--warning); font-weight: 700; }
    .severity-info { color: var(--info); font-weight: 700; }
    .empty { padding: 1.25rem; border: 1px dashed var(--line); border-radius: .5rem; background: var(--panel); }
    footer { margin-top: 2rem; padding: 1rem 0 2rem; color: var(--muted); border-top: 1px solid var(--line); }
  </style>
</head>
<body data-status="{{ result.summary.status.value }}">
  <header>
    <h1>Utility Network Schema QA Report</h1>
    <p class="meta"><strong>Project:</strong> {{ result.project_name }}</p>
    <p class="meta"><strong>Toolkit:</strong> {{ result.toolkit_version }} · <strong>Fingerprint:</strong> <code>{{ result.input_fingerprint }}</code></p>
  </header>
  <main>
    <section aria-label="Validation summary" class="summary">
      <div class="card"><span>Status</span><strong class="status">{{ result.summary.status.value }}</strong></div>
      <div class="card"><span>Total</span><strong>{{ result.summary.total }}</strong></div>
      <div class="card"><span>Errors</span><strong>{{ result.summary.counts.error }}</strong></div>
      <div class="card"><span>Warnings</span><strong>{{ result.summary.counts.warning }}</strong></div>
      <div class="card"><span>Info</span><strong>{{ result.summary.counts.info }}</strong></div>
    </section>
    <p class="meta"><strong>Validators run:</strong> {{ result.validators | join(', ') if result.validators else 'None' }}</p>
    {% if groups %}
      {% for validator, findings in groups %}
      <section aria-labelledby="validator-{{ loop.index }}">
        <h2 id="validator-{{ loop.index }}">{{ validator }}</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Severity</th><th>Code</th><th>Affected item</th><th>Message</th><th>Recommendation</th></tr></thead>
            <tbody>
            {% for item in findings %}
              <tr>
                <td class="severity-{{ item.severity.value }}">{{ item.severity.value }}</td>
                <td><code>{{ item.code }}</code></td>
                <td>{{ item.dataset or '—' }}{% if item.field %} / {{ item.field }}{% endif %}{% if item.mapping_id %}<br>Mapping: {{ item.mapping_id }}{% endif %}</td>
                <td>{{ item.message }}</td>
                <td>{{ item.recommendation }}</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
      </section>
      {% endfor %}
    {% else %}
      <section aria-labelledby="findings-empty">
        <h2 id="findings-empty">Findings</h2>
        <p class="empty">No findings were reported.</p>
      </section>
    {% endif %}
  </main>
  <footer>Generated by Utility Network Schema QA Toolkit {{ result.toolkit_version }}.</footer>
</body>
</html>

